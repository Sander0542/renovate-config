{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":automergePatch",
    ":semanticCommits"
  ],
  "ignorePresets": [
    ":semanticPrefixFixDepsChoreOthers"
  ],
  "labels": [
    "dependencies",
    "{{manager}}",
    "{{updateType}}"
  ],
  "autodiscover": true,
  "prHourlyLimit": 0
}
